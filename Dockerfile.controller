# Controller image. One Dockerfile, four images — built by GoReleaser
# (`dockers_v2` in .goreleaser.yaml), which compiles the binaries first and
# hands this file a build context containing ONLY those binaries, laid out as
# $TARGETPLATFORM/<binary> (e.g. linux/amd64/source-controller). There is no
# Go toolchain or source here: version metadata is already stamped into
# internal/version by GoReleaser's ldflags, and the same buildx invocation
# produces the linux/amd64 + linux/arm64 manifest.
#
# TARGET selects the binary to copy; RUNTIME selects the final base:
#
#   RUNTIME=static (default) — gcr.io/distroless/static-debian12:nonroot.
#     Correct for source-controller, context-controller, and webhook-controller:
#     pure Go, CGO off, no external process is ever executed.
#   RUNTIME=git — debian:12-slim with git + ca-certificates.
#     REQUIRED for remediation-controller: internal/gitpush shells out to the
#     `git` binary (clone / fetch bundle / push) when it publishes an agent's
#     changeset, so a static distroless image would fail at push time with
#     "exec: git: executable file not found".
#
# Both args are supplied by the per-image `build_args` in .goreleaser.yaml.
# Build locally (no publish) with `make snapshot` — needs docker + buildx.
#
# Both runtimes run as uid 65532 ("nonroot"), matching internal/jobs'
# runAsUser, and both work under readOnlyRootFilesystem provided /tmp is an
# emptyDir — gitpush uses os.MkdirTemp for its scratch clone.

# An ARG interpolated into a FROM must be declared BEFORE the first FROM
# (global scope); declared any later it belongs to the preceding stage and
# the FROM sees an empty string.
ARG RUNTIME=static

# ---- runtime: static (source-controller, context-controller) ---------------
FROM gcr.io/distroless/static-debian12:nonroot AS runtime-static

# ---- runtime: git (remediation-controller) ----------------------------------
FROM debian:12-slim AS runtime-git
# hadolint ignore=DL3008
RUN apt-get update \
    && apt-get install --no-install-recommends -y ca-certificates git \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --gid 65532 nonroot \
    && useradd --uid 65532 --gid 65532 --create-home --home-dir /home/nonroot --shell /sbin/nologin nonroot

# ---- final -----------------------------------------------------------------
FROM runtime-${RUNTIME}

ARG TARGETPLATFORM
ARG TARGET

# The binary lands at a fixed path so ENTRYPOINT need not interpolate TARGET
# (exec-form ENTRYPOINT cannot expand build args). The Deployment supplies the
# subcommand: args: ["serve"].
COPY ${TARGETPLATFORM}/${TARGET} /usr/local/bin/controller

USER 65532:65532
EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/controller"]
